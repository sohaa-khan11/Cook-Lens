ack italic tracking-tighter text-on-surface uppercase\">Execution</h2>\n                  <div className=\"flex-1 h-px bg-gradient-to-r from-primary/30 to-transparent\"></div>\n                </div>\n                <div className=\"space-y-24\">\n                  {[\n                    { title: \"Bloom the Saffron\", text: \"Crush threads heavily. Steep in warm water for exactly 10 minutes.\" },\n                    { title: \"Roast\", text: \"Arrange florets with absolute space. Blast at 400┬░F. Do not interrupt for 25 minutes.\", img: \"https://lh3.googleusercontent.com/aida-public/AB6AXuCFNOg_dqdEKbA-kdN-xhixWFAOHgmBM3ZrDz_a9ICWNbV-UKX-WA3vZMXP84lLh7LchP1HVHuH3f7xkYliZVr4ouslZycO0hRVXBIi3Mh95nhGqctaWqVN0VRI-YE-fNODZk2nQ4pSumVk7o7qKRyFHpeG2l_PUPvAevwKv2ELCuqLsfmfkKh8_ag5Pm5gVMcNPk8IO0lskppvfnKhng2DPHiZpGtmWYl67oNyJBoTG0F0qvyfWL0DESfP0v8TgUFC0K5HvBO9ZcY\" },\n                  ].map((step, idx) => (\n                    <motion.div \n                      key={idx} \n                      initial={{ opacity: 0, y: 50 }}\n                      whileInView={{ opacity: 1, y: 0 }}\n                      viewport={{ once: true, margin: \"-150px\" }}\n                      transition={{ duration: 1.2, ease: CINEMATIC_EASE }}\n                      className=\"relative pl-12 border-l border-white/10 group\"\n                    >\n                      <div className=\"absolute -left-[1.5px] top-0 w-[3px] h-0 bg-primary group-hover:h-full transition-all duration-1000 ease-out\" />\n                      <div className=\"absolute -left-[20px] top-0 w-10 h-10 rounded-full bg-neutral-900 border border-white/10 flex items-center justify-center text-lg font-black text-primary italic shadow-2xl\">\n                        {idx + 1}\n                      </div>\n                      \n                      <h3 className=\"text-2xl font-black italic tracking-tighter text-on-surface mb-4 pt-1\">{step.title}</h3>\n                      <p className=\"text-lg leading-relaxed t